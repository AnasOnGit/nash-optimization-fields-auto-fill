{
  "manifest_version": 3,
  "name": "Nash Capacity Pro",
  "version": "1.1",
  "description": "Premium bulk automation for Nash",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon32.png",
    "128": "icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.usenash.com/*"],
      "js": ["content.js"]
    }
  ]
}
